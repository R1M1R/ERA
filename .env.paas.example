# ERA — PaaS deployment (Render + Neon + Upstash + Vercel)
# Copy values into Render/Vercel dashboards. Never commit secrets.

# --- Neon PostgreSQL (https://neon.tech) ---
# Use the pooled connection string; ERA converts postgresql:// to asyncpg automatically.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/era_db?sslmode=require
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/era_db?sslmode=require

# --- Upstash Redis (https://upstash.com) ---
# Use the TLS URL (rediss://) for Celery on PaaS.
REDIS_URL=rediss://default:PASSWORD@global-xxx.upstash.io:6379
CELERY_BROKER_URL=rediss://default:PASSWORD@global-xxx.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@global-xxx.upstash.io:6379

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- ERA secrets ---
ERA_SERVER_SALT=replace-with-long-random-secret

# --- CORS: your Vercel frontend URL ---
CORS_ORIGINS=https://your-project.vercel.app

# --- PaaS tuning (Render free tier) ---
GUNICORN_WORKERS=1
PYTHONPATH=/app

# --- Frontend (Vercel env) ---
# VITE_API_URL=https://era-api.onrender.com
