# ERA — Standalone local mode (NO Docker required)
# Copy: copy .env.standalone.example .env
# Run:  .\scripts\start-standalone.ps1

ERA_STANDALONE=true
ERA_DEMO_MODE=true

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
ERA_SERVER_SALT=dev-salt-change-me-in-production

# SQLite DB is created automatically at backend/era_standalone.db
# Celery runs in-process (no Redis, no separate worker)
