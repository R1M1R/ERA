# ERA — Environment Template
# Copy to `.env`. Never commit `.env`.

# --- Local development (Windows / macOS) ---
# Use localhost — postgres and redis run via `docker compose up -d postgres redis`
#
# POSTGRES_USER=era
# POSTGRES_PASSWORD=era_secret
# POSTGRES_DB=era_db
# DATABASE_URL=postgresql+asyncpg://era:era_secret@localhost:5432/era_db
# DATABASE_URL_SYNC=postgresql+psycopg2://era:era_secret@localhost:5432/era_db
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Production (Docker Compose on server) ---
# Use service hostnames postgres / redis, not localhost.

POSTGRES_USER=era
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=era_db

# Use Docker service hostnames (postgres / redis), not localhost.
DATABASE_URL=postgresql+asyncpg://era:replace-with-strong-password@postgres:5432/era_db
DATABASE_URL_SYNC=postgresql+psycopg2://era:replace-with-strong-password@postgres:5432/era_db

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

ERA_SERVER_SALT=replace-with-long-random-secret

# Comma-separated frontend origins for CORS (production example)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# IP-only testing on Oracle Cloud (before domain):
# CORS_ORIGINS=http://YOUR_PUBLIC_IP
