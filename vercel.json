{
  "buildCommand": "cd frontend && npm ci && npm run build",
  "installCommand": "cd frontend && npm ci",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/openapi.json", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/generate", "destination": "/api" },
    { "source": "/status/:path*", "destination": "/api" },
    { "source": "/artifacts/:path*", "destination": "/api" },
    { "source": "/artifacts", "destination": "/api" },
    { "source": "/verify", "destination": "/api" },
    { "source": "/pro/status", "destination": "/api" },
    { "source": "/pro/activate", "destination": "/api" },
    { "source": "/webhooks/lemonsqueezy", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "includeFiles": "backend/**,worker/**"
    }
  },
  "env": {
    "ERA_STANDALONE": "true",
    "ERA_DEMO_MODE": "true"
  }
}
