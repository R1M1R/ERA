# ERA — Local development (.env)
# Copy:  copy .env.local.example .env
# Never commit .env

POSTGRES_USER=era
POSTGRES_PASSWORD=era_secret
POSTGRES_DB=era_db

DATABASE_URL=postgresql+asyncpg://era:era_secret@localhost:5432/era_db
DATABASE_URL_SYNC=postgresql+psycopg2://era:era_secret@localhost:5432/era_db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

ERA_SERVER_SALT=dev-salt-change-me-in-production

# Use demo riddles without OpenAI (local dev). Set false when using a real API key.
ERA_DEMO_MODE=true

# CORS defaults to localhost:5173 when unset
