# Same-origin API in production (Vercel). Local override:
# VITE_API_URL=http://127.0.0.1:8000

# Pro checkout (Lemon Squeezy / Paddle / Gumroad) — owner only, see docs/MONETIZATION.ru.md
# VITE_PRO_PAYMENT_LINK=https://your-store.lemonsqueezy.com/checkout/buy/...

# Show beta / test-mode notice and block Pro checkout until production_ready (default: true)
# VITE_APP_BETA_MODE=true
